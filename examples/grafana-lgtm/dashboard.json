{
  "title": "@damngamerz/pi-otel",
  "uid": "damngamerz-pi-otel",
  "schemaVersion": 38,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "tags": [
    "damngamerz",
    "gen-ai",
    "local",
    "opentelemetry",
    "otel",
    "pi"
  ],
  "annotations": {
    "list": []
  },
  "templating": {
    "list": []
  },
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Request rate (req/min)",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum(rate(gen_ai_client_operation_duration_seconds_count{gen_ai_system=\"pi\"}[5m])) * 60",
          "legendFormat": "req/min",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Average LLM duration",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 30
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum(rate(gen_ai_client_operation_duration_seconds_sum{gen_ai_system=\"pi\"}[5m])) / sum(rate(gen_ai_client_operation_duration_seconds_count{gen_ai_system=\"pi\"}[5m]))",
          "legendFormat": "avg",
          "refId": "A"
        }
      ]
    },
